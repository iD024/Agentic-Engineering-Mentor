{
  "name": "@engineering-workspace/runtime",
  "version": "0.1.0",
  "description": "Engineering Workspace Runtime v2 — Application Foundation",
  "type": "module",
  "main": "dist/src/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc && cp -r src/database/migrations dist/src/database/",
    "start": "node dist/src/main.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/pdf-parse": "^1.1.5",
    "better-sqlite3": "^12.11.1",
    "cheerio": "^1.2.0",
    "chokidar": "^5.0.0",
    "dotenv": "^16.4.7",
    "Parser": "^0.0.1",
    "pdf-parse": "^2.4.5",
    "web-tree-sitter": "^0.26.11",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "eslint": "^9.25.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
