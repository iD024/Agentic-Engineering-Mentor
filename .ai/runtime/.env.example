# Engineering Workspace Runtime — Environment Configuration
# Copy this file to .env and adjust values as needed.

# Application environment: development | production | test
NODE_ENV=development

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# Root directory for the workspace. Defaults to the current working directory (.).
# During development inside .ai/runtime/, you may want to set this to ../.. to target the repository root.
WORKSPACE_ROOT=../..

# Maximum time (ms) to wait for graceful shutdown before force-exiting
SHUTDOWN_TIMEOUT_MS=10000
